# =============================================================================
# Auto-Renewal Keeper — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# The on-chain package ID after deploying the auto_renewal::vault module.
# Deploy with: sui client publish --gas-budget 100000000
# Then copy the published package ID from the output.
PACKAGE_ID=

# The Walrus System shared object ID on the target network.
# On Testnet: find it via `sui client object` or Walrus documentation.
SYSTEM_OBJECT_ID=

# ---------------------------------------------------------------------------
# Keeper Worker
# ---------------------------------------------------------------------------

# Ed25519 private key for the keeper's gas wallet (base64-encoded 64-byte key).
# Generate one with:
#   sui keytool generate ed25519
# Or in TypeScript:
#   new Ed25519Keypair().getSecretKey()
#
# Format: base64 string of the 64-byte Ed25519 secret key.
KEEPER_PRIVATE_KEY=

# Cron schedule for scanning vaults (default: every 2 minutes)
# SCAN_SCHEDULE=*/2 * * * *

# Max vaults to process per scan cycle (default: 50)
# MAX_VAULTS_PER_CYCLE=50

# Retry delay on failure in ms (default: 5000)
# RETRY_DELAY_MS=5000

# Enable event-based vault discovery as a fallback when suix_queryObjects fails.
# When enabled, the keeper will query VaultCreated events to discover vaults
# if the primary on-chain object query is unavailable (e.g., restricted RPC).
# Note: Only finds vaults created within the event query window.
# ENABLE_EVENT_FALLBACK=false

# ---------------------------------------------------------------------------
# RPC Endpoints
# ---------------------------------------------------------------------------

# Sui RPC URL (default: Testnet)
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# For local development:
# SUI_RPC_URL=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# Notification Service
# ---------------------------------------------------------------------------

# Email address to receive keeper alerts (e.g., InsufficientBalance).
# NOTIFICATION_EMAIL=admin@example.com

# Webhook URL for alert POSTs (JSON payload).
# The keeper will POST alert events to this URL.
# NOTIFICATION_WEBHOOK_URL=https://hooks.example.com/alerts

# Optional HMAC secret for webhook payload signing (SHA-256 HMAC).
# If set, the webhook POST will include an X-Signature-256 header.
# NOTIFICATION_WEBHOOK_SECRET=

# Resend API key (https://resend.com) for email delivery.
# If set, alerts will be sent via email to NOTIFICATION_EMAIL.
# Get an API key at: https://resend.com/api-keys
# RESEND_API_KEY=re_...

# Sender email address for Resend emails (must be verified in Resend).
# Default: alerts@autorenewal.app
# NOTIFICATION_FROM_EMAIL=alerts@autorenewal.app

# Set to 'false' to disable console logging of notifications.
# NOTIFICATION_ENABLE_CONSOLE=true

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------

# Port for the REST API (default: 3001)
# PORT=3001

# ---------------------------------------------------------------------------
# UI
# ---------------------------------------------------------------------------

# Sui RPC URL for the frontend (default: Testnet)
# VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
